# Haruspex configuration. Copy to .env and edit. Never commit .env.
# Every variable here is read through pydantic-settings (backend) or the SDK.

# --- Database ---------------------------------------------------------------
# Async SQLAlchemy URL for api + worker. docker-compose overrides this to the
# in-network db host; this default targets the compose-published port (55432,
# chosen to avoid colliding with host-local Postgres installs) for local
# (non-container) development.
HARUSPEX_DATABASE_URL=postgresql+asyncpg://haruspex:haruspex@localhost:55432/haruspex

# Credentials the compose db container is created with (change both together).
POSTGRES_USER=haruspex
POSTGRES_PASSWORD=haruspex
POSTGRES_DB=haruspex

# --- API service --------------------------------------------------------------
# Comma-separated browser-origin allowlist for CORS.
HARUSPEX_CORS_ORIGINS=http://localhost:5173,http://localhost:8080
# Log level for structlog output (debug|info|warning|error).
HARUSPEX_LOG_LEVEL=info

# --- Worker -------------------------------------------------------------------
# Seconds between forecast refits per active run.
HARUSPEX_WORKER_INTERVAL_S=15
# Heartbeats older than this mark a run LOST.
HARUSPEX_HEARTBEAT_STALE_S=120

# --- The Analyst (optional — everything else works without it) ---------------
# Anthropic API key. When unset the Analyst panel shows a setup card; nothing
# crashes and no other feature degrades.
ANTHROPIC_API_KEY=
# Model used by the Analyst.
HARUSPEX_COPILOT_MODEL=claude-sonnet-4-6
